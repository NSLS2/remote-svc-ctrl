  <widget type="group" version="3.0.0">
    <name>Controls</name>
    <x>5</x>
    <y>560</y>
    <width>495</width>
    <height>80</height>
    <foreground_color>
      <color red="0" green="149" blue="255">
      </color>
    </foreground_color>
    <transparent>true</transparent>
    <widget type="action_button" version="3.0.0">
      <name>Start</name>
      <actions>
        <action type="write_pv">
          <pv_name>$(PREFIX)Start</pv_name>
          <value>1</value>
          <description>Start Service</description>
        </action>
      </actions>
      <text>Start</text>
      <x>17</x>
      <y>7</y>
      <width>125</width>
      <height>35</height>
      <foreground_color>
        <color name="Background" red="255" green="255" blue="255">
        </color>
      </foreground_color>
      <background_color>
        <color red="0" green="128" blue="0">
        </color>
      </background_color>
      <tooltip>$(actions)</tooltip>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>Stop</name>
      <actions>
        <action type="write_pv">
          <pv_name>$(PREFIX)Stop</pv_name>
          <value>1</value>
          <description>Stop Service</description>
        </action>
      </actions>
      <text>Stop</text>
      <x>164</x>
      <y>7</y>
      <width>125</width>
      <height>35</height>
      <foreground_color>
        <color red="255" green="255" blue="255">
        </color>
      </foreground_color>
      <background_color>
        <color name="MAJOR" red="255" green="0" blue="0">
        </color>
      </background_color>
      <tooltip>$(actions)</tooltip>
      <show_confirm_dialog>true</show_confirm_dialog>
    </widget>
    <widget type="action_button" version="3.0.0">
      <name>Restart</name>
      <actions>
        <action type="write_pv">
          <pv_name>$(PREFIX)Restart</pv_name>
          <value>1</value>
          <description>Restart Service</description>
        </action>
      </actions>
      <text>Restart</text>
      <x>314</x>
      <y>7</y>
      <width>125</width>
      <height>35</height>
      <tooltip>$(actions)</tooltip>
      <show_confirm_dialog>true</show_confirm_dialog>
    </widget>
  </widget>
