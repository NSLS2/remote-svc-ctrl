  <!-- Start Button -->
  <widget type="action_button" version="2.0.0">
    <name>Start</name>
    <text>Start</text>
    <x>5</x>
    <y>480</y>
    <width>150</width>
    <height>35</height>
    <actions>
      <action type="write_pv">
        <pv_name>$(PREFIX):Start</pv_name>
        <value>1</value>
        <description>Start Service</description>
      </action>
    </actions>
  </widget>

  <!-- Stop Button -->
  <widget type="action_button" version="2.0.0">
    <name>Stop</name>
    <text>Stop</text>
    <x>170</x>
    <y>480</y>
    <width>150</width>
    <height>35</height>
    <actions>
      <action type="write_pv">
        <pv_name>$(PREFIX):Stop</pv_name>
        <value>1</value>
        <description>Stop Service</description>
      </action>
    </actions>
  </widget>

  <!-- Restart Button -->
  <widget type="action_button" version="2.0.0">
    <name>Restart</name>
    <text>Restart</text>
    <x>335</x>
    <y>480</y>
    <width>150</width>
    <height>35</height>
    <actions>
