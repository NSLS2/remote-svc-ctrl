<?xml version='1.0' encoding='UTF-8'?>
<display version="2.0.0">
  <name>Service Control</name>
  <macros>
    <PREFIX>$(PREFIX)</PREFIX>
  </macros>
  <width>500</width>
  <height>550</height>

  <!-- Title -->
  <widget type="label" version="2.0.0">
    <name>Title</name>
    <text>Service Control - $(PREFIX)</text>
    <x>5</x>
    <y>5</y>
    <width>490</width>
    <height>30</height>
    <font>
      <font name="Header 1" family="Liberation Sans" style="BOLD" size="18"/>
    </font>
  </widget>

  <!-- Unit -->
  <widget type="label" version="2.0.0">
    <name>Unit Label</name>
    <text>Unit</text>
    <x>5</x>
    <y>45</y>
    <width>120</width>
    <height>25</height>
  </widget>
  <widget type="textupdate" version="2.0.0">
    <name>Unit</name>
    <pv_name>$(PREFIX):Unit</pv_name>
    <x>130</x>
    <y>45</y>
    <width>360</width>
    <height>25</height>
  </widget>

