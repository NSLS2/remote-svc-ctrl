    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>Enabled</name>
      <pv_name>$(PREFIX)Enabled</pv_name>
      <x>92</x>
      <y>132</y>
      <width>360</width>
      <height>25</height>
      <horizontal_alignment>1</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
      <rules>
        <rule name="TextColor" prop_id="foreground_color" out_exp="false">
          <exp bool_exp="pv0==0">
            <value>
              <color red="0" green="128" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==1">
            <value>
              <color red="204" green="51" blue="51">
              </color>
            </value>
          </exp>
          <pv_name>$(PREFIX)Enabled</pv_name>
        </rule>
      </rules>
    </widget>
    <widget type="label" version="2.0.0">
      <name>ActiveState Label</name>
      <text>Active State</text>
      <y>162</y>
      <width>120</width>
      <height>25</height>
    </widget>
    <widget type="textupdate" version="2.0.0">
      <name>ActiveState</name>
      <pv_name>$(PREFIX)ActiveState</pv_name>
      <x>92</x>
      <y>162</y>
      <width>360</width>
      <height>25</height>
      <horizontal_alignment>1</horizontal_alignment>
      <vertical_alignment>1</vertical_alignment>
      <rules>
        <rule name="TextColor" prop_id="foreground_color" out_exp="false">
          <exp bool_exp="pv0==0">
            <value>
              <color red="0" green="128" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0==1 || pv0==4">
            <value>
              <color red="255" green="255" blue="0">
              </color>
            </value>
          </exp>
          <exp bool_exp="pv0 != 0 &amp;&amp; pv0 != 1 &amp;&amp; pv0 != 4">
            <value>
              <color red="255" green="0" blue="0">
              </color>
            </value>
          </exp>
          <pv_name>$(PREFIX)ActiveState</pv_name>
        </rule>
      </rules>
    </widget>
